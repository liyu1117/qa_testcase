# QA Master 环境变量配置

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./backend/data/qa_master.db

# 豆包 AI 模型
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_API_BASE_URL=https://maas-api.ml-platform-cn-beijing.volces.com/api/v3
DOUBAO_CHAT_MODEL=doubao-pro-32k
DOUBAO_CODE_MODEL=doubao-pro-32k
DOUBAO_VISION_MODEL=doubao-vision-pro-32k
DOUBAO_EMBEDDING_MODEL=doubao-embedding

# 钉钉
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_WEBHOOK_SECRET=your_webhook_secret

# Figma
FIGMA_ACCESS_TOKEN=your_figma_token

# YApi
YAPI_BASE_URL=http://your-yapi-host
YAPI_TOKEN=your_yapi_token

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
